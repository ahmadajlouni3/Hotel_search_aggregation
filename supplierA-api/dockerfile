FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Apache + PHP + required extensions
RUN apt-get update && \
    apt-get install -y \
    apache2 \
    php \
    php-cli \
    php-mbstring \
    php-xml \
    php-intl \
    php-curl \
    unzip \
    curl \
    git \
    libicu-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Fix Apache warning and enable rewrite
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf && \
    a2enmod rewrite

# Allow .htaccess overrides
RUN sed -i 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# Set DocumentRoot to /var/www/html
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html|g' /etc/apache2/sites-available/000-default.conf

# Enable PHP error reporting
RUN echo "display_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "display_startup_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "error_reporting = E_ALL" >> /etc/php/8.3/apache2/php.ini

# Set working directory
WORKDIR /var/www/html

# Copy CodeIgniter backend code
COPY ./ /var/www/html

# Create .htaccess automatically
RUN echo '<IfModule mod_rewrite.c>\n\
RewriteEngine On\n\
RewriteCond %{REQUEST_FILENAME} !-f\n\
RewriteCond %{REQUEST_FILENAME} !-d\n\
RewriteRule ^(.*)$ index.php/$1 [L]\n\
</IfModule>' > /var/www/html/.htaccess

# Fix writable folder permissions
RUN chown -R www-data:www-data /var/www/html/writable && \
    chmod -R 775 /var/www/html/writable

# Expose Apache port
EXPOSE 80

# Start Apache in foreground
CMD ["apache2ctl", "-D", "FOREGROUND"]
