FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Apache + PHP + required extensions
RUN apt-get update && \
    apt-get install -y \
        apache2 \
        php \
        php-cli \
        php-mbstring \
        php-xml \
        php-intl \
        php-curl \
        unzip \
        curl \
        git \
        libicu-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Enable Apache rewrite and fix ServerName warning
RUN a2enmod rewrite && echo "ServerName localhost" >> /etc/apache2/apache2.conf

# Allow .htaccess overrides
RUN sed -i '/<Directory \/var\/www\/>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

# Set Apache DocumentRoot to CI public folder
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/public|g' /etc/apache2/sites-available/000-default.conf

# Enable PHP error reporting for debugging
RUN echo "display_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "display_startup_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "error_reporting = E_ALL" >> /etc/php/8.3/apache2/php.ini

# Set working directory
WORKDIR /var/www/html

# Copy backend project files
COPY ./ /var/www/html

# Install Composer (for dependencies)
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Install PHP dependencies for CI4
RUN composer install --no-dev --optimize-autoloader

# Fix writable permissions for logs/cache
RUN chown -R www-data:www-data /var/www/html/writable && chmod -R 775 /var/www/html/writable

# Add .htaccess to public/ to route all requests through index.php
RUN echo '<IfModule mod_rewrite.c>\n\
RewriteEngine On\n\
RewriteCond %{REQUEST_FILENAME} !-f\n\
RewriteCond %{REQUEST_FILENAME} !-d\n\
RewriteRule ^(.*)$ index.php/$1 [L]\n\
</IfModule>' > /var/www/html/public/.htaccess

# Expose Apache port
EXPOSE 80

# Start Apache in foreground
CMD ["apache2ctl", "-D", "FOREGROUND"]
