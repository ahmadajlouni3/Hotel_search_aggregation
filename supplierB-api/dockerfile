FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Apache + PHP + required extensions
RUN apt-get update && \
    apt-get install -y \
    apache2 \
    php \
    php-cli \
    php-mbstring \
    php-xml \
    php-intl \
    php-curl \
    unzip \
    curl \
    git \
    libicu-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Fix Apache warning and enable rewrite
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf && \
    a2enmod rewrite

# Allow .htaccess overrides for routing
RUN sed -i 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# DocumentRoot can remain as html (no front-end), just make sure index.php is reachable
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html|g' /etc/apache2/sites-available/000-default.conf

# Enable PHP error reporting for easier debugging
RUN echo "display_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "display_startup_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "error_reporting = E_ALL" >> /etc/php/8.3/apache2/php.ini

# Set working directory
WORKDIR /var/www/html

# Copy your CodeIgniter project (backend only)
COPY ./ /var/www/html

# Fix CodeIgniter writable permissions
RUN chown -R www-data:www-data /var/www/html/writable && \
    chmod -R 775 /var/www/html/writable

# Expose Apache port
EXPOSE 80

# Start Apache in foreground
CMD ["apache2ctl", "-D", "FOREGROUND"]
