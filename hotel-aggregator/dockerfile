# Use latest Ubuntu as base
FROM ubuntu:latest

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install PHP, required extensions, and other tools
RUN apt-get update && apt-get install -y php-cli php-mbstring php-xml unzip curl git libicu-dev

# Install Composer globally
RUN curl -sS https://getcomposer.org/installer | php && mv composer.phar /usr/local/bin/composer

# Set working directory inside container
WORKDIR /home/ubuntu

# Copy application code from host to container
# Make sure to replace './hotel-aggregator' with your actual host path
COPY ./ /home/ubuntu
RUN composer -v
RUN composer install

RUN ls

# Expose port 8080
EXPOSE 8080

# Set environment to production (not development)
ENV CI_ENVIRONMENT = production

# Run CodeIgniter server on container start
CMD ["php", "spark", "serve", "--host=0.0.0.0", "--port=8080"]
