FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install Apache + PHP + required extensions
RUN apt-get update && \
    apt-get install -y \
    apache2 \
    php \
    php-cli \
    php-mbstring \
    php-xml \
    php-intl \
    php-curl \
    unzip \
    curl \
    git \
    libicu-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Enable Apache modules and fix ServerName warning
RUN echo "ServerName localhost" >> /etc/apache2/apache2.conf && \
    a2enmod rewrite

# Allow .htaccess overrides for routing
RUN sed -i 's/AllowOverride None/AllowOverride All/g' /etc/apache2/apache2.conf

# Change Apache DocumentRoot to CodeIgniter public folder
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/public|g' /etc/apache2/sites-available/000-default.conf

# Enable PHP error reporting for easier debugging
RUN echo "display_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "display_startup_errors = On" >> /etc/php/8.3/apache2/php.ini && \
    echo "error_reporting = E_ALL" >> /etc/php/8.3/apache2/php.ini

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Set working directory
WORKDIR /var/www/html

# Copy project files
COPY ./ /var/www/html

# Rename search page to main page
RUN if [ -f /var/www/html/public/search.html ]; then \
    mv /var/www/html/public/search.html /var/www/html/public/index.html; \
    fi

# Fix CodeIgniter writable permissions recursively
RUN chown -R www-data:www-data /var/www/html/writable && \
    chmod -R 775 /var/www/html/writable

# Expose web port
EXPOSE 80

# Start Apache in foreground
CMD ["apache2ctl", "-D", "FOREGROUND"]
